# API keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Model IDs. Resolve at execution time from each provider's docs.
# Training-data knowledge of version numbers is reliably stale; check first.
#   OpenAI:    https://platform.openai.com/docs/models
#   Anthropic: https://docs.anthropic.com/en/docs/about-claude/models
#   Gemini:    https://ai.google.dev/gemini-api/docs/models
MODEL_ID_OPENAI_FLAGSHIP=
MODEL_ID_OPENAI_CHEAP=
MODEL_ID_ANTHROPIC_FLAGSHIP=
MODEL_ID_ANTHROPIC_CHEAP=
MODEL_ID_GEMINI_FLAGSHIP=
MODEL_ID_GEMINI_CHEAP=

# Optional overrides
BENCH_CONCURRENCY=10
BENCH_RESULTS_DIR=./results
